<Window x:Class="NeuroPlayer_HighRes_V2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NEURO PLAYER - Bit-Perfect Flux Edition" Height="550" Width="450" Background="#111111" 
        ResizeMode="CanMinimize" 
        WindowStartupLocation="CenterScreen">
    <Grid Margin="25">
        <StackPanel>
            <TextBlock Text="NEURO PLAYER V2" Foreground="#00E6B8" FontWeight="Bold" FontSize="26" HorizontalAlignment="Center" Margin="0,5,0,5"/>
            <TextBlock Text="192 kHz / 32-Bit Float | Zero-Latency Engine" Foreground="#888888" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <TextBlock x:Name="FileLabel" Text="Keine Datei geladen" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Border Background="#1A1A1A" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="DAC STATUS:" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="StatusMainLabel" Text="BEREIT" Foreground="White" FontWeight="Bold" FontSize="18" Margin="0,0,0,5"/>
                    <TextBlock x:Name="StatusSubLabel" Text="Warte auf Audio-Datei..." Foreground="#00E6B8" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="OUTPUT DEVICE (ASIO EXCLUSIVE):" Foreground="#666666" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="DeviceComboBox" Background="White" Foreground="Black" FontSize="14" Padding="5" Margin="0,0,0,20"/>

            <TextBlock x:Name="TimeLabel" Text="00:00 / 00:00" Foreground="#00E6B8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <Slider x:Name="ProgressSlider" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,20" IsEnabled="True"
                    Thumb.DragStarted="ProgressSlider_DragStarted" 
                    Thumb.DragCompleted="ProgressSlider_DragCompleted"/>

            <CheckBox x:Name="LoopCheckBox" Content="GAPLESS LOOP (RAM RING-BUFFER)" Foreground="White" HorizontalAlignment="Center" IsChecked="False" Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="LADEN" Click="Laden_Click" Background="#333333" Foreground="White" FontWeight="Bold" Height="45" BorderThickness="0"/>
                <Button Grid.Column="2" Content="PLAY" Click="Play_Click" Background="#00E6B8" Foreground="Black" FontWeight="Bold" Height="45" BorderThickness="0"/>
                <Button Grid.Column="4" Content="STOP" Click="Stop_Click" Background="#FF3344" Foreground="White" FontWeight="Bold" Height="45" BorderThickness="0"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>